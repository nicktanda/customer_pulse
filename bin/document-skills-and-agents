#!/usr/bin/env ruby
# frozen_string_literal: true

# Regenerates docs/skills-and-agents.md from:
#   - .claude/skills/*/SKILL.md (YAML frontmatter: name, description)
#   - .github/workflows/ci.yml (job names)
#   - .github/dependabot.yml (package ecosystems)
#   - Gemfile (sentry-rails presence)
#
# Usage:
#   bin/document-skills-and-agents          # write docs/skills-and-agents.md
#   bin/document-skills-and-agents --check  # same, then exit 1 if git diff is dirty (for CI)
#
require "yaml"
require "time"
require "fileutils"
require "open3"

ROOT = File.expand_path("..", __dir__)
OUTPUT = File.join(ROOT, "docs", "skills-and-agents.md")

def skill_dirs
  base = File.join(ROOT, ".claude", "skills")
  return [] unless Dir.exist?(base)

  Dir.children(base).sort.filter_map do |entry|
    path = File.join(base, entry)
    next unless File.directory?(path)

    skill_md = File.join(path, "SKILL.md")
    next unless File.file?(skill_md)

    [ entry, skill_md ]
  end
end

def parse_skill_frontmatter(path)
  raw = File.read(path, encoding: "UTF-8")
  return nil unless raw.start_with?("---\n")

  parts = raw.split(/^---\s*$/, 3)
  return nil if parts.length < 3

  data = YAML.safe_load(parts[1], permitted_classes: [ Symbol ], aliases: true)
  return nil unless data.is_a?(Hash)

  name = data["name"].to_s.strip
  desc = data["description"]
  desc = desc.is_a?(String) ? desc.strip.gsub(/\s+/, " ") : ""

  { "name" => name, "description" => desc }
rescue Psych::SyntaxError, ArgumentError
  { "name" => File.basename(File.dirname(path)), "description" => "(could not parse frontmatter)" }
end

def ci_jobs
  path = File.join(ROOT, ".github", "workflows", "ci.yml")
  return [] unless File.file?(path)

  y = YAML.load_file(path)
  y.is_a?(Hash) && y["jobs"].is_a?(Hash) ? y["jobs"].keys.sort : []
rescue StandardError
  []
end

def dependabot_updates
  path = File.join(ROOT, ".github", "dependabot.yml")
  return [] unless File.file?(path)

  y = YAML.load_file(path)
  return [] unless y.is_a?(Hash) && y["updates"].is_a?(Array)

  y["updates"].filter_map { |u| u["package-ecosystem"] }.compact.uniq.sort
rescue StandardError
  []
end

def sentry_configured_in_gemfile?
  gemfile = File.join(ROOT, "Gemfile")
  return false unless File.file?(gemfile)

  File.read(gemfile, encoding: "UTF-8").include?("sentry-rails")
end

def build_markdown
  lines = []
  lines << "# Skills and automation inventory"
  lines << ""
  lines << "<!-- AUTO-GENERATED by bin/document-skills-and-agents — do not edit by hand. -->"
  lines << "<!-- Run `bin/document-skills-and-agents` after adding or renaming skills. -->"
  lines << ""
  lines << "Generated at: **#{Time.now.utc.iso8601}** (UTC)"
  lines << ""
  lines << "Human-readable guides: **[`docs/agents.md`](agents.md)** (automation), **[`CLAUDE.md`](../CLAUDE.md)** (Claude Code context)."
  lines << ""
  lines << "## Claude Code skills"
  lines << ""
  lines << "Each row is a folder under `.claude/skills/<folder>/` with a `SKILL.md` file. Descriptions come from YAML frontmatter."
  lines << ""

  rows = skill_dirs.filter_map do |folder, path|
    fm = parse_skill_frontmatter(path)
    next unless fm

    [ folder, fm["name"], fm["description"] ]
  end

  if rows.empty?
    lines << "*(No skills found under `.claude/skills/`.)*"
    lines << ""
  else
    lines << "| Folder | `name` (frontmatter) | Description |"
    lines << "|--------|------------------------|-------------|"
    rows.each do |folder, name, desc|
      safe_desc = desc.gsub("|", "\\|")
      lines << "| `#{folder}` | #{name} | #{safe_desc} |"
    end
    lines << ""
  end

  lines << "## Automation (agents)"
  lines << ""
  lines << "These entries are **derived from config files**; narrative detail stays in **[`docs/agents.md`](agents.md)**."
  lines << ""

  jobs = ci_jobs
  if jobs.any?
    lines << "### GitHub Actions CI jobs (`ci.yml`)"
    lines << ""
    lines << "| Job |"
    lines << "|-----|"
    jobs.each { |j| lines << "| `#{j}` |" }
    lines << ""
  else
    lines << "### GitHub Actions"
    lines << ""
    lines << "*(Could not read `.github/workflows/ci.yml`.)*"
    lines << ""
  end

  eco = dependabot_updates
  if eco.any?
    lines << "### Dependabot (`dependabot.yml`)"
    lines << ""
    lines << "Package ecosystems: #{eco.map { |e| "`#{e}`" }.join(', ')}."
    lines << ""
  end

  lines << "### Optional Sentry"
  lines << ""
  if sentry_configured_in_gemfile?
    lines << "`sentry-rails` is listed in the `Gemfile` (production group). Set **`SENTRY_DSN`** in production — see `docs/agents.md`."
  else
    lines << "*(`sentry-rails` not detected in Gemfile.)*"
  end
  lines << ""

  lines << "## Regenerating this file"
  lines << ""
  lines << "```bash"
  lines << "bin/document-skills-and-agents"
  lines << "```"
  lines << ""
  lines << "In CI, the **`docs_inventory`** job runs `bin/document-skills-and-agents --check` and fails if the committed file is out of date."
  lines << ""

  lines.join("\n")
end

def main
  check = ARGV.include?("--check")

  FileUtils.mkdir_p(File.dirname(OUTPUT))

  File.write(OUTPUT, build_markdown)

  puts "Wrote #{OUTPUT}"

  return unless check

  _out, _err, st = Open3.capture3("git", "-C", ROOT, "diff", "--exit-code", "--", OUTPUT)
  return if st.success?

  warn "docs/skills-and-agents.md is out of date. Run: bin/document-skills-and-agents"
  warn "Then commit the updated file."
  exit 1
end

main
