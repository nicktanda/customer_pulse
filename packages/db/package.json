{
  "name": "@customer-pulse/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./lockbox": "./src/lockbox.ts",
    "./control-plane": "./src/control-plane-client.ts",
    "./control-plane-schema": "./src/control-plane-schema.ts",
    "./tenant-connection-manager": "./src/tenant-connection-manager.ts",
