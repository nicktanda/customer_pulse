<% content_for :title, "#{@objective.title} - Customer Pulse" %>

<div class="mb-6">
  <%= link_to business_objectives_path, class: "text-indigo-600 hover:text-indigo-800 text-sm flex items-center" do %>
    <svg class="h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Back to Objectives
  <% end %>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2 space-y-6">
    <div class="bg-white rounded-lg shadow">
      <div class="px-6 py-4 border-b border-gray-200">
        <div class="flex items-center justify-between">
          <div class="flex items-center">
            <div class="p-3 rounded-lg <%= objective_type_bg(@objective.objective_type) %>">
              <%= objective_type_icon(@objective.objective_type) %>
            </div>
            <div class="ml-4">
              <h1 class="text-xl font-semibold text-gray-900"><%= @objective.title %></h1>
              <p class="text-sm text-gray-500"><%= @objective.objective_type_label %></p>
            </div>
          </div>
          <div class="flex items-center space-x-2">
            <%= render partial: "business_objectives/priority_badge", locals: { priority: @objective.priority } %>
            <span class="px-3 py-1 text-sm font-medium rounded <%= objective_status_badge(@objective.status) %>">
              <%= @objective.status_label %>
            </span>
          </div>
        </div>
      </div>

      <div class="px-6 py-4">
        <% if @objective.description.present? %>
          <div class="mb-6">
            <h3 class="text-sm font-medium text-gray-500 mb-2">Description</h3>
            <p class="text-gray-900 whitespace-pre-wrap"><%= @objective.description %></p>
          </div>
        <% end %>

        <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <dt class="text-sm font-medium text-gray-500">Target Date</dt>
            <dd class="mt-1 text-sm <%= @objective.overdue? ? 'text-red-600 font-medium' : 'text-gray-900' %>">
              <% if @objective.target_date.present? %>
                <%= @objective.target_date.strftime("%B %d, %Y") %>
                <% if @objective.overdue? %>
                  <span class="text-xs">(Overdue by <%= (-@objective.days_until_target).abs %> days)</span>
                <% elsif @objective.days_until_target && @objective.days_until_target > 0 %>
                  <span class="text-gray-500 text-xs">(<%= @objective.days_until_target %> days remaining)</span>
                <% end %>
              <% else %>
                Not set
              <% end %>
            </dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">Active</dt>
            <dd class="mt-1 text-sm text-gray-900">
              <% if @objective.active? %>
                <span class="inline-flex items-center text-green-600">
                  <svg class="h-4 w-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                  Yes
                </span>
              <% else %>
                <span class="text-gray-500">No</span>
              <% end %>
            </dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">Created</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @objective.created_at.strftime("%B %d, %Y") %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">Last Updated</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @objective.updated_at.strftime("%B %d, %Y at %H:%M") %></dd>
          </div>
        </dl>
      </div>
    </div>

    <% if @objective.success_metrics.present? %>
      <div class="bg-white rounded-lg shadow">
        <div class="px-6 py-4 border-b border-gray-200">
          <h2 class="text-lg font-semibold text-gray-900">Success Metrics</h2>
        </div>
        <div class="px-6 py-4">
          <p class="text-gray-700 whitespace-pre-wrap"><%= @objective.success_metrics %></p>
        </div>
      </div>
    <% end %>
  </div>

  <div class="space-y-6">
    <div class="bg-white rounded-lg shadow">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900">Actions</h2>
      </div>
      <div class="px-6 py-4 space-y-3">
        <% if current_project_user&.can_manage_project? %>
          <%= link_to "Edit Objective", edit_business_objective_path(@objective), class: "block w-full text-center bg-indigo-600 text-white px-4 py-2 rounded-md hover:bg-indigo-700 text-sm font-medium" %>

          <% if @objective.active? && @objective.status == "active" %>
            <%= button_to "Mark as Achieved", business_objective_path(@objective), method: :patch, params: { business_objective: { status: :achieved } }, class: "w-full bg-green-100 text-green-700 px-4 py-2 rounded-md hover:bg-green-200 text-sm font-medium" %>
          <% end %>

          <% if @objective.active? %>
            <%= button_to "Pause Objective", business_objective_path(@objective), method: :patch, params: { business_objective: { status: :paused } }, class: "w-full bg-yellow-100 text-yellow-700 px-4 py-2 rounded-md hover:bg-yellow-200 text-sm font-medium" %>
          <% elsif @objective.paused? %>
            <%= button_to "Resume Objective", business_objective_path(@objective), method: :patch, params: { business_objective: { status: :active } }, class: "w-full bg-blue-100 text-blue-700 px-4 py-2 rounded-md hover:bg-blue-200 text-sm font-medium" %>
          <% end %>

          <hr class="my-4">
          <%= button_to "Delete Objective", business_objective_path(@objective), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this objective?" }, class: "w-full bg-red-100 text-red-700 px-4 py-2 rounded-md hover:bg-red-200 text-sm font-medium" %>
        <% end %>
      </div>
    </div>

    <div class="bg-gradient-to-br from-indigo-50 to-purple-50 rounded-lg p-6 border border-indigo-100">
      <div class="flex items-start">
        <div class="p-2 bg-indigo-100 rounded-lg">
          <svg class="h-5 w-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-indigo-900">AI Alignment</h3>
          <p class="mt-1 text-sm text-indigo-700">
            Active objectives are used by the AI to score how well feedback and insights align with your business goals.
          </p>
        </div>
      </div>
    </div>
  </div>
</div>
