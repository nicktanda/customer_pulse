<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Customer Pulse" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="min-h-screen bg-gray-50">
    <% if user_signed_in? %>
      <nav class="bg-gradient-to-r from-indigo-600 via-indigo-600 to-indigo-700 shadow-lg sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex justify-between h-16">
            <div class="flex items-center">
              <%= link_to root_path, class: "flex items-center text-white font-bold text-xl group" do %>
                <div class="p-1.5 bg-white/10 rounded-lg mr-2 group-hover:bg-white/20 transition-colors">
                  <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                  </svg>
                </div>
                Customer Pulse
              <% end %>

              <div class="hidden md:flex ml-10 space-x-1">
                <%= link_to "Dashboard", root_path, class: "nav-link hover:bg-white/10 #{request.path == root_path ? 'bg-indigo-700/50' : ''}" %>
                <%= link_to "Feedback", feedback_index_path, class: "nav-link hover:bg-white/10 #{request.path.start_with?('/feedback') ? 'bg-indigo-700/50' : ''}" %>
                <%= link_to "Integrations", integrations_path, class: "nav-link hover:bg-white/10 #{request.path.start_with?('/integrations') ? 'bg-indigo-700/50' : ''}" %>
                <%= link_to "Recipients", recipients_path, class: "nav-link hover:bg-white/10 #{request.path.start_with?('/recipients') ? 'bg-indigo-700/50' : ''}" %>
                <%= link_to "Reports", pulse_reports_path, class: "nav-link hover:bg-white/10 #{request.path.start_with?('/pulse_reports') ? 'bg-indigo-700/50' : ''}" %>
                <%= link_to "Settings", settings_path, class: "nav-link hover:bg-white/10 #{request.path.start_with?('/settings') ? 'bg-indigo-700/50' : ''}" %>
                <%= link_to "Skills", skills_path, class: "nav-link hover:bg-white/10 #{request.path.start_with?('/skills') ? 'bg-indigo-700/50' : ''}" %>
              </div>
            </div>

            <div class="flex items-center space-x-4">
              <!-- Project Switcher -->
              <% if current_user.projects.any? %>
                <div class="relative" data-controller="dropdown">
                  <button type="button" data-action="click->dropdown#toggle" class="flex items-center text-white hover:bg-white/10 px-3 py-2 rounded-lg text-sm font-medium transition-all">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/>
                    </svg>
                    <span class="max-w-32 truncate"><%= current_project&.name || 'Select Project' %></span>
                    <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                  </button>
                  <div data-dropdown-target="menu" class="hidden absolute right-0 mt-2 w-56 bg-white rounded-lg shadow-lg border border-gray-200 py-1 z-50">
                    <div class="px-3 py-2 text-xs font-semibold text-gray-400 uppercase tracking-wider">Projects</div>
                    <% current_user.projects.alphabetical.each do |project| %>
                      <%= button_to switch_project_path(project), method: :post, class: "w-full text-left px-3 py-2 text-sm hover:bg-gray-50 flex items-center justify-between #{current_project&.id == project.id ? 'bg-indigo-50 text-indigo-700' : 'text-gray-700'}" do %>
                        <span class="truncate"><%= project.name %></span>
                        <% if current_project&.id == project.id %>
                          <svg class="w-4 h-4 text-indigo-600" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                          </svg>
                        <% end %>
                      <% end %>
                    <% end %>
                    <div class="border-t border-gray-200 mt-1 pt-1">
                      <%= link_to projects_path, class: "block px-3 py-2 text-sm text-gray-700 hover:bg-gray-50" do %>
                        <svg class="w-4 h-4 inline-block mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                        Manage Projects
                      <% end %>
                    </div>
                  </div>
                </div>
              <% end %>

              <span class="text-indigo-100 text-sm hidden sm:flex items-center">
                <span class="w-2 h-2 bg-green-400 rounded-full mr-2 animate-pulse"></span>
                <%= current_user.name || current_user.email %>
                <% if current_user.admin? %>
                  <span class="bg-white/20 text-xs px-2 py-0.5 rounded-full ml-2 font-medium">Admin</span>
                <% end %>
              </span>
              <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "text-white hover:bg-white/10 px-3 py-2 rounded-lg text-sm font-medium transition-all" %>

              <!-- Mobile menu button -->
              <button type="button" class="md:hidden inline-flex items-center justify-center p-2 rounded-lg text-white hover:bg-white/10 transition-colors" onclick="document.getElementById('mobile-menu').classList.toggle('hidden')">
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
              </button>
            </div>
          </div>
        </div>

        <!-- Mobile menu -->
        <div id="mobile-menu" class="hidden md:hidden border-t border-indigo-500/30">
          <div class="px-4 py-3 space-y-1">
            <%= link_to "Dashboard", root_path, class: "block px-3 py-2 rounded-lg text-white hover:bg-white/10 text-sm font-medium #{request.path == root_path ? 'bg-indigo-700/50' : ''}" %>
            <%= link_to "Feedback", feedback_index_path, class: "block px-3 py-2 rounded-lg text-white hover:bg-white/10 text-sm font-medium #{request.path.start_with?('/feedback') ? 'bg-indigo-700/50' : ''}" %>
            <%= link_to "Integrations", integrations_path, class: "block px-3 py-2 rounded-lg text-white hover:bg-white/10 text-sm font-medium #{request.path.start_with?('/integrations') ? 'bg-indigo-700/50' : ''}" %>
            <%= link_to "Recipients", recipients_path, class: "block px-3 py-2 rounded-lg text-white hover:bg-white/10 text-sm font-medium #{request.path.start_with?('/recipients') ? 'bg-indigo-700/50' : ''}" %>
            <%= link_to "Reports", pulse_reports_path, class: "block px-3 py-2 rounded-lg text-white hover:bg-white/10 text-sm font-medium #{request.path.start_with?('/pulse_reports') ? 'bg-indigo-700/50' : ''}" %>
            <%= link_to "Settings", settings_path, class: "block px-3 py-2 rounded-lg text-white hover:bg-white/10 text-sm font-medium #{request.path.start_with?('/settings') ? 'bg-indigo-700/50' : ''}" %>
            <%= link_to "Skills", skills_path, class: "block px-3 py-2 rounded-lg text-white hover:bg-white/10 text-sm font-medium #{request.path.start_with?('/skills') ? 'bg-indigo-700/50' : ''}" %>
          </div>
        </div>
      </nav>
    <% end %>

    <main class="<%= user_signed_in? ? 'max-w-7xl mx-auto py-6 px-4 sm:px-6 lg:px-8' : '' %>">
      <% if notice %>
        <div class="mb-4 flash-message flash-success animate-in fade-in duration-300" role="alert">
          <svg class="h-5 w-5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span class="flex-1"><%= notice %></span>
          <button type="button" onclick="this.parentElement.remove()" class="ml-3 text-green-600 hover:text-green-800 transition-colors">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      <% end %>

      <% if alert %>
        <div class="mb-4 flash-message flash-error animate-in fade-in duration-300" role="alert">
          <svg class="h-5 w-5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span class="flex-1"><%= alert %></span>
          <button type="button" onclick="this.parentElement.remove()" class="ml-3 text-red-600 hover:text-red-800 transition-colors">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
