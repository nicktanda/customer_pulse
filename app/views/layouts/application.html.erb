<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Customer Pulse" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="min-h-screen bg-gray-50">
    <% if user_signed_in? %>
      <nav class="bg-gradient-to-r from-indigo-600 via-indigo-600 to-indigo-700 shadow-lg sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex justify-between h-16">
            <div class="flex items-center">
              <%= link_to root_path, class: "flex items-center text-white font-bold text-xl group" do %>
                <div class="p-1.5 bg-white/10 rounded-lg mr-2 group-hover:bg-white/20 transition-colors">
                  <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                  </svg>
                </div>
                Customer Pulse
              <% end %>

              <div class="hidden md:flex ml-10 space-x-1">
                <%= link_to "Dashboard", root_path, class: "nav-link hover:bg-white/10 #{request.path == root_path ? 'bg-indigo-700/50' : ''}" %>
                <%= link_to "Feedback", feedback_index_path, class: "nav-link hover:bg-white/10 #{request.path.start_with?('/feedback') ? 'bg-indigo-700/50' : ''}" %>
                <%= link_to "Integrations", integrations_path, class: "nav-link hover:bg-white/10 #{request.path.start_with?('/integrations') ? 'bg-indigo-700/50' : ''}" %>
                <%= link_to "Recipients", recipients_path, class: "nav-link hover:bg-white/10 #{request.path.start_with?('/recipients') ? 'bg-indigo-700/50' : ''}" %>
                <%= link_to "Reports", pulse_reports_path, class: "nav-link hover:bg-white/10 #{request.path.start_with?('/pulse_reports') ? 'bg-indigo-700/50' : ''}" %>
                <% if current_user.admin? %>
                  <%= link_to "Settings", settings_path, class: "nav-link hover:bg-white/10 #{request.path.start_with?('/settings') ? 'bg-indigo-700/50' : ''}" %>
                <% end %>
              </div>
            </div>

            <div class="flex items-center space-x-4">
              <span class="text-indigo-100 text-sm hidden sm:flex items-center">
                <span class="w-2 h-2 bg-green-400 rounded-full mr-2 animate-pulse"></span>
                <%= current_user.name || current_user.email %>
                <% if current_user.admin? %>
                  <span class="bg-white/20 text-xs px-2 py-0.5 rounded-full ml-2 font-medium">Admin</span>
                <% end %>
              </span>
              <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "text-white hover:bg-white/10 px-3 py-2 rounded-lg text-sm font-medium transition-all" %>

              <!-- Mobile menu button -->
              <button type="button" class="md:hidden inline-flex items-center justify-center p-2 rounded-lg text-white hover:bg-white/10 transition-colors" onclick="document.getElementById('mobile-menu').classList.toggle('hidden')">
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
              </button>
            </div>
          </div>
        </div>

        <!-- Mobile menu -->
        <div id="mobile-menu" class="hidden md:hidden border-t border-indigo-500/30">
          <div class="px-4 py-3 space-y-1">
            <%= link_to "Dashboard", root_path, class: "block px-3 py-2 rounded-lg text-white hover:bg-white/10 text-sm font-medium #{request.path == root_path ? 'bg-indigo-700/50' : ''}" %>
            <%= link_to "Feedback", feedback_index_path, class: "block px-3 py-2 rounded-lg text-white hover:bg-white/10 text-sm font-medium #{request.path.start_with?('/feedback') ? 'bg-indigo-700/50' : ''}" %>
            <%= link_to "Integrations", integrations_path, class: "block px-3 py-2 rounded-lg text-white hover:bg-white/10 text-sm font-medium #{request.path.start_with?('/integrations') ? 'bg-indigo-700/50' : ''}" %>
            <%= link_to "Recipients", recipients_path, class: "block px-3 py-2 rounded-lg text-white hover:bg-white/10 text-sm font-medium #{request.path.start_with?('/recipients') ? 'bg-indigo-700/50' : ''}" %>
            <%= link_to "Reports", pulse_reports_path, class: "block px-3 py-2 rounded-lg text-white hover:bg-white/10 text-sm font-medium #{request.path.start_with?('/pulse_reports') ? 'bg-indigo-700/50' : ''}" %>
            <% if current_user.admin? %>
              <%= link_to "Settings", settings_path, class: "block px-3 py-2 rounded-lg text-white hover:bg-white/10 text-sm font-medium #{request.path.start_with?('/settings') ? 'bg-indigo-700/50' : ''}" %>
            <% end %>
          </div>
        </div>
      </nav>
    <% end %>

    <main class="<%= user_signed_in? ? 'max-w-7xl mx-auto py-6 px-4 sm:px-6 lg:px-8' : '' %>">
      <% if notice %>
        <div class="mb-4 flash-message flash-success animate-in fade-in duration-300" role="alert">
          <svg class="h-5 w-5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span class="flex-1"><%= notice %></span>
          <button type="button" onclick="this.parentElement.remove()" class="ml-3 text-green-600 hover:text-green-800 transition-colors">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      <% end %>

      <% if alert %>
        <div class="mb-4 flash-message flash-error animate-in fade-in duration-300" role="alert">
          <svg class="h-5 w-5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span class="flex-1"><%= alert %></span>
          <button type="button" onclick="this.parentElement.remove()" class="ml-3 text-red-600 hover:text-red-800 transition-colors">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
