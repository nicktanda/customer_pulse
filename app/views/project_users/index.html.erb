<div class="max-w-4xl mx-auto space-y-6">
  <div class="mb-6">
    <%= link_to @project, class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700" do %>
      <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Back to <%= @project.name %>
    <% end %>
  </div>

  <!-- Header -->
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Team Members</h1>
      <p class="mt-1 text-sm text-gray-500">Manage who has access to <%= @project.name %></p>
    </div>
  </div>

  <!-- Add Member Form -->
  <div class="card">
    <div class="p-5 border-b border-gray-200">
      <h2 class="text-lg font-medium text-gray-900">Add Team Member</h2>
    </div>
    <div class="p-5">
      <%= form_with url: project_project_users_path(@project), method: :post, class: "flex flex-col sm:flex-row gap-3" do |f| %>
        <div class="flex-1">
          <%= f.email_field :email, placeholder: "Enter email address", class: "form-input-enhanced w-full", required: true %>
        </div>
        <%= f.submit "Add Member", class: "btn-primary whitespace-nowrap cursor-pointer" %>
      <% end %>
      <p class="mt-2 text-xs text-gray-500">The user must already have a Customer Pulse account.</p>
    </div>
  </div>

  <!-- Members List -->
  <div class="card">
    <div class="p-5 border-b border-gray-200">
      <h2 class="text-lg font-medium text-gray-900">Current Members (<%= @project_users.count %>)</h2>
    </div>
    <ul class="divide-y divide-gray-200">
      <% @project_users.each do |project_user| %>
        <li class="p-4">
          <div class="flex items-center justify-between">
            <div class="flex items-center min-w-0">
              <% if project_user.user.avatar_url.present? %>
                <img src="<%= project_user.user.avatar_url %>" alt="" class="w-10 h-10 rounded-full flex-shrink-0">
              <% else %>
                <div class="w-10 h-10 rounded-full bg-indigo-100 flex items-center justify-center flex-shrink-0">
                  <span class="text-indigo-600 font-medium text-sm"><%= project_user.user.name&.first&.upcase || project_user.user.email.first.upcase %></span>
                </div>
              <% end %>
              <div class="ml-3 min-w-0">
                <div class="text-sm font-medium text-gray-900 truncate">
                  <%= project_user.user.name || project_user.user.email %>
                  <% if project_user.user == current_user %>
                    <span class="text-gray-500">(you)</span>
                  <% end %>
                  <% if project_user.is_owner? %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-purple-100 text-purple-800 ml-1">Owner</span>
                  <% end %>
                </div>
                <div class="text-sm text-gray-500 truncate"><%= project_user.user.email %></div>
                <% if project_user.invited_by.present? %>
                  <div class="text-xs text-gray-400">Invited by <%= project_user.invited_by.name || project_user.invited_by.email %></div>
                <% end %>
              </div>
            </div>

            <div class="flex items-center gap-2 ml-4">
              <!-- Remove button (not for owner or self) -->
              <% unless project_user.is_owner? || project_user.user == current_user %>
                <%= button_to project_project_user_path(@project, project_user), method: :delete, data: { turbo_confirm: "Are you sure you want to remove #{project_user.user.name || project_user.user.email} from this project?" }, class: "text-red-600 hover:text-red-800 p-1.5" do %>
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                  </svg>
                <% end %>
              <% end %>
            </div>
          </div>
        </li>
      <% end %>
    </ul>
  </div>
</div>
