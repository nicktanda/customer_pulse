<div data-controller="integration-setup">
  <div class="flex items-center mb-6">
    <div class="w-12 h-12 bg-gradient-to-br from-blue-500 to-blue-700 rounded-xl flex items-center justify-center mr-4">
      <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="currentColor">
        <path d="M11.571 11.513H0a5.218 5.218 0 0 0 5.232 5.215h2.13v2.057A5.215 5.215 0 0 0 12.575 24V12.518a1.005 1.005 0 0 0-1.005-1.005zm5.723-5.756H5.736a5.215 5.215 0 0 0 5.215 5.214h2.129v2.058a5.218 5.218 0 0 0 5.215 5.214V6.758a1.001 1.001 0 0 0-1.001-1.001zM23.013 0H11.455a5.215 5.215 0 0 0 5.215 5.215h2.129v2.057A5.215 5.215 0 0 0 24 12.483V1.005A1.005 1.005 0 0 0 23.013 0z"/>
      </svg>
    </div>
    <div>
      <h2 class="text-2xl font-bold text-gray-900">Jira Integration</h2>
      <p class="text-gray-500">Import issues and bugs from Jira</p>
    </div>
    <span class="ml-auto px-3 py-1 bg-gray-100 text-gray-600 text-sm font-medium rounded-full">Optional</span>
  </div>

  <div class="bg-blue-50 border border-blue-200 rounded-xl p-4 mb-6">
    <div class="flex">
      <svg class="w-5 h-5 text-blue-600 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <div>
        <h4 class="font-medium text-blue-800 mb-1">How to set up Jira</h4>
        <ol class="text-sm text-blue-700 space-y-1 list-decimal list-inside">
          <li>Go to <a href="https://id.atlassian.com/manage-profile/security/api-tokens" target="_blank" class="underline hover:text-blue-900">Atlassian API tokens</a></li>
          <li>Click "Create API token"</li>
          <li>Give it a name like "Customer Pulse"</li>
          <li>Copy the generated token</li>
        </ol>
      </div>
    </div>
  </div>

  <%= form_with url: update_step_onboarding_path, method: :post, data: { turbo_frame: "_top" }, local: true do |f| %>
    <%= hidden_field_tag :step, "jira" %>

    <div class="space-y-4 mb-6">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Jira Site URL</label>
        <input type="text"
               name="integration[site_url]"
               value="<%= @integration&.parsed_credentials&.dig('site_url') %>"
               placeholder="https://yourcompany.atlassian.net"
               class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
               data-integration-setup-target="field"
               data-field="site_url">
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
        <input type="email"
               name="integration[email]"
               value="<%= @integration&.parsed_credentials&.dig('email') %>"
               placeholder="you@company.com"
               class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
               data-integration-setup-target="field"
               data-field="email">
        <p class="text-xs text-gray-500 mt-1">The email associated with your Atlassian account</p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">API Token</label>
        <input type="password"
               name="integration[api_token]"
               value="<%= @integration&.parsed_credentials&.dig('api_token') %>"
               placeholder="ATATT3xFfGF0xxxxxxxxxxxx"
               class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
               data-integration-setup-target="field"
               data-field="api_token">
      </div>
    </div>

    <!-- Connection Test -->
    <div class="mb-8">
      <button type="button"
              class="w-full py-3 px-4 bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium rounded-xl transition-colors flex items-center justify-center"
              data-action="click->integration-setup#testConnection"
              data-integration-setup-type-param="jira">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
        </svg>
        Test Connection
      </button>
      <div id="connection-result" class="mt-4"></div>
    </div>

    <div class="flex justify-between">
      <button type="submit" name="skip" value="1" class="text-gray-500 hover:text-gray-700 font-medium px-4 py-2 transition-colors">
        Skip for now
      </button>
      <button type="submit" class="btn-primary px-6 py-2.5">
        Continue
        <svg class="w-4 h-4 ml-2 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </button>
    </div>
  <% end %>
</div>
