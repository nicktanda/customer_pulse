<div data-controller="integration-setup">
  <div class="flex items-center mb-6">
    <div class="w-12 h-12 bg-gradient-to-br from-violet-500 to-purple-700 rounded-xl flex items-center justify-center mr-4">
      <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
      </svg>
    </div>
    <div>
      <h2 class="text-2xl font-bold text-gray-900">LogRocket Integration</h2>
      <p class="text-gray-500">Import session replays and user feedback</p>
    </div>
    <span class="ml-auto px-3 py-1 bg-gray-100 text-gray-600 text-sm font-medium rounded-full">Optional</span>
  </div>

  <div class="bg-violet-50 border border-violet-200 rounded-xl p-4 mb-6">
    <div class="flex">
      <svg class="w-5 h-5 text-violet-600 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <div>
        <h4 class="font-medium text-violet-800 mb-1">How to set up LogRocket</h4>
        <ol class="text-sm text-violet-700 space-y-1 list-decimal list-inside">
          <li>Go to <a href="https://app.logrocket.com/settings/api" target="_blank" class="underline hover:text-violet-900">LogRocket API Settings</a></li>
          <li>Find your App ID (shown in your snippet code)</li>
          <li>Generate or copy your API Key</li>
          <li>Paste both values below</li>
        </ol>
      </div>
    </div>
  </div>

  <%= form_with url: update_step_onboarding_path, method: :post, data: { turbo_frame: "_top" }, local: true do |f| %>
    <%= hidden_field_tag :step, "logrocket" %>

    <div class="space-y-4 mb-6">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">App ID</label>
        <input type="text"
               name="integration[app_id]"
               value="<%= @integration&.parsed_credentials&.dig('app_id') %>"
               placeholder="your-org/your-app"
               class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
               data-integration-setup-target="field"
               data-field="app_id">
        <p class="text-xs text-gray-500 mt-1">Found in your LogRocket snippet: LogRocket.init('your-org/your-app')</p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">API Key</label>
        <input type="password"
               name="integration[api_key]"
               value="<%= @integration&.parsed_credentials&.dig('api_key') %>"
               placeholder="lr_xxxxxxxxxxxxxxxxxxxx"
               class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
               data-integration-setup-target="field"
               data-field="api_key">
      </div>
    </div>

    <!-- Connection Test -->
    <div class="mb-8">
      <button type="button"
              class="w-full py-3 px-4 bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium rounded-xl transition-colors flex items-center justify-center"
              data-action="click->integration-setup#testConnection"
              data-integration-setup-type-param="logrocket">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
        </svg>
        Test Connection
      </button>
      <div id="connection-result" class="mt-4"></div>
    </div>

    <div class="flex justify-between">
      <button type="submit" name="skip" value="1" class="text-gray-500 hover:text-gray-700 font-medium px-4 py-2 transition-colors">
        Skip for now
      </button>
      <button type="submit" class="btn-primary px-6 py-2.5">
        Continue
        <svg class="w-4 h-4 ml-2 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </button>
    </div>
  <% end %>
</div>
