<div data-controller="integration-setup">
  <div class="flex items-center mb-6">
    <div class="w-12 h-12 bg-gradient-to-br from-gray-700 to-gray-900 rounded-xl flex items-center justify-center mr-4">
      <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="currentColor">
        <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
      </svg>
    </div>
    <div>
      <h2 class="text-2xl font-bold text-gray-900">GitHub Integration</h2>
      <p class="text-gray-500">Connect your repository to generate PRs from Ideas</p>
    </div>
    <span class="ml-auto px-3 py-1 bg-gray-100 text-gray-600 text-sm font-medium rounded-full">Optional</span>
  </div>

  <div class="bg-gray-50 border border-gray-200 rounded-xl p-4 mb-6">
    <div class="flex">
      <svg class="w-5 h-5 text-gray-600 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <div>
        <h4 class="font-medium text-gray-800 mb-1">How to create a GitHub Personal Access Token</h4>
        <ol class="text-sm text-gray-700 space-y-1 list-decimal list-inside">
          <li>Go to <a href="https://github.com/settings/tokens?type=beta" target="_blank" class="underline hover:text-gray-900">github.com/settings/tokens</a></li>
          <li>Click "Generate new token" (fine-grained)</li>
          <li>Select the repository you want to connect</li>
          <li>Grant "Contents" (Read and write) and "Pull requests" (Read and write) permissions</li>
          <li>Click "Generate token" and copy the value</li>
        </ol>
      </div>
    </div>
  </div>

  <%= form_with url: update_step_onboarding_path, method: :post, data: { turbo_frame: "_top" }, local: true do |f| %>
    <%= hidden_field_tag :step, "github" %>

    <div class="space-y-4 mb-6">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Access Token</label>
        <input type="password"
               name="integration[access_token]"
               value="<%= @integration&.parsed_credentials&.dig('access_token') %>"
               placeholder="github_pat_xxxxxxxxxxxx"
               class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-gray-500 focus:border-gray-500"
               data-integration-setup-target="field"
               data-field="access_token">
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Owner</label>
          <input type="text"
                 name="integration[owner]"
                 value="<%= @integration&.parsed_credentials&.dig('owner') %>"
                 placeholder="your-org or username"
                 class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-gray-500 focus:border-gray-500"
                 data-integration-setup-target="field"
                 data-field="owner">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Repository</label>
          <input type="text"
                 name="integration[repo]"
                 value="<%= @integration&.parsed_credentials&.dig('repo') %>"
                 placeholder="repository-name"
                 class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-gray-500 focus:border-gray-500"
                 data-integration-setup-target="field"
                 data-field="repo">
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Default Branch</label>
        <input type="text"
               name="integration[default_branch]"
               value="<%= @integration&.parsed_credentials&.dig('default_branch') || 'main' %>"
               placeholder="main"
               class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-gray-500 focus:border-gray-500"
               data-integration-setup-target="field"
               data-field="default_branch">
        <p class="mt-1 text-sm text-gray-500">The branch to create PRs against (usually main or master)</p>
      </div>
    </div>

    <!-- Connection Test -->
    <div class="mb-8">
      <button type="button"
              class="w-full py-3 px-4 bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium rounded-xl transition-colors flex items-center justify-center"
              data-action="click->integration-setup#testConnection"
              data-integration-setup-type-param="github">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
        </svg>
        Test Connection
      </button>
      <div id="connection-result" class="mt-4"></div>
    </div>

    <div class="flex justify-between">
      <button type="submit" name="skip" value="1" class="text-gray-500 hover:text-gray-700 font-medium px-4 py-2 transition-colors">
        Skip for now
      </button>
      <button type="submit" class="btn-primary px-6 py-2.5">
        Continue
        <svg class="w-4 h-4 ml-2 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </button>
    </div>
  <% end %>
</div>
