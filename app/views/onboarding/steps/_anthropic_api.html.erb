<div data-controller="integration-setup">
  <div class="flex items-center mb-6">
    <div class="w-12 h-12 bg-gradient-to-br from-orange-400 to-orange-600 rounded-xl flex items-center justify-center mr-4">
      <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
      </svg>
    </div>
    <div>
      <h2 class="text-2xl font-bold text-gray-900">Anthropic API Setup</h2>
      <p class="text-gray-500">Required for AI-powered feedback analysis</p>
    </div>
    <span class="ml-auto px-3 py-1 bg-red-100 text-red-700 text-sm font-medium rounded-full">Required</span>
  </div>

  <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 mb-6">
    <div class="flex">
      <svg class="w-5 h-5 text-amber-600 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <div>
        <h4 class="font-medium text-amber-800 mb-1">How to get your API key</h4>
        <ol class="text-sm text-amber-700 space-y-1 list-decimal list-inside">
          <li>Go to <a href="https://console.anthropic.com" target="_blank" class="underline hover:text-amber-900">console.anthropic.com</a></li>
          <li>Sign in or create an account</li>
          <li>Navigate to "API Keys" in the sidebar</li>
          <li>Click "Create Key" and copy your new API key</li>
          <li>Set it as the <code class="bg-amber-100 px-1 rounded">ANTHROPIC_API_KEY</code> environment variable</li>
        </ol>
      </div>
    </div>
  </div>

  <div class="bg-gray-50 rounded-xl p-6 mb-6">
    <h4 class="font-medium text-gray-900 mb-3">Environment Variable Status</h4>
    <% if ENV['ANTHROPIC_API_KEY'].present? %>
      <div class="flex items-center text-green-600">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <span class="font-medium">ANTHROPIC_API_KEY is configured</span>
      </div>
      <p class="text-sm text-gray-500 mt-2">Key ending in: ...****<%= ENV['ANTHROPIC_API_KEY'][-4..] %></p>
    <% else %>
      <div class="flex items-center text-red-600">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
        <span class="font-medium">ANTHROPIC_API_KEY is not set</span>
      </div>
      <p class="text-sm text-gray-500 mt-2">Please set the environment variable and restart the application.</p>
    <% end %>
  </div>

  <!-- Connection Test -->
  <div class="mb-8">
    <button type="button"
            class="w-full py-3 px-4 bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium rounded-xl transition-colors flex items-center justify-center"
            data-action="click->integration-setup#testConnection"
            data-integration-setup-type-param="anthropic"
            <%= 'disabled' if ENV['ANTHROPIC_API_KEY'].blank? %>>
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
      </svg>
      Test Connection
    </button>
    <div id="connection-result" class="mt-4"></div>
  </div>

  <%= form_with url: update_step_onboarding_path, method: :post, data: { turbo_frame: "_top" } do |f| %>
    <%= hidden_field_tag :step, "anthropic_api" %>

    <div class="flex justify-between">
      <div></div>
      <button type="submit" class="btn-primary px-6 py-2.5" <%= 'disabled' if ENV['ANTHROPIC_API_KEY'].blank? %>>
        Continue
        <svg class="w-4 h-4 ml-2 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </button>
    </div>
  <% end %>
</div>
