<div data-controller="integration-setup">
  <div class="flex items-center mb-6">
    <div class="w-12 h-12 bg-gradient-to-br from-green-500 to-emerald-600 rounded-xl flex items-center justify-center mr-4">
      <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12.013 2.25c-5.476 0-9.913 4.438-9.913 9.913s4.437 9.913 9.913 9.913 9.912-4.438 9.912-9.913-4.436-9.913-9.912-9.913zm3.075 14.85l-5.025-3.35v-6.7h1.5v5.9l4.35 2.9-.825 1.25z"/>
      </svg>
    </div>
    <div>
      <h2 class="text-2xl font-bold text-gray-900">Zendesk Integration</h2>
      <p class="text-gray-500">Import support tickets and customer feedback</p>
    </div>
    <span class="ml-auto px-3 py-1 bg-gray-100 text-gray-600 text-sm font-medium rounded-full">Optional</span>
  </div>

  <div class="bg-green-50 border border-green-200 rounded-xl p-4 mb-6">
    <div class="flex">
      <svg class="w-5 h-5 text-green-600 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <div>
        <h4 class="font-medium text-green-800 mb-1">How to set up Zendesk</h4>
        <ol class="text-sm text-green-700 space-y-1 list-decimal list-inside">
          <li>Go to Admin Center > Apps and integrations > APIs > Zendesk API</li>
          <li>Enable "Token Access"</li>
          <li>Click "Add API token"</li>
          <li>Copy your subdomain from your Zendesk URL (e.g., yourcompany.zendesk.com)</li>
        </ol>
      </div>
    </div>
  </div>

  <%= form_with url: update_step_onboarding_path, method: :post, data: { turbo_frame: "_top" }, local: true do |f| %>
    <%= hidden_field_tag :step, "zendesk" %>

    <div class="space-y-4 mb-6">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Subdomain</label>
        <div class="flex items-center">
          <input type="text"
                 name="integration[subdomain]"
                 value="<%= @integration&.parsed_credentials&.dig('subdomain') %>"
                 placeholder="yourcompany"
                 class="w-full px-4 py-3 border border-gray-300 rounded-l-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
                 data-integration-setup-target="field"
                 data-field="subdomain">
          <span class="px-4 py-3 bg-gray-100 border border-l-0 border-gray-300 rounded-r-xl text-gray-500">.zendesk.com</span>
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
        <input type="email"
               name="integration[email]"
               value="<%= @integration&.parsed_credentials&.dig('email') %>"
               placeholder="you@company.com"
               class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
               data-integration-setup-target="field"
               data-field="email">
        <p class="text-xs text-gray-500 mt-1">The email of a Zendesk admin account</p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">API Token</label>
        <input type="password"
               name="integration[api_token]"
               value="<%= @integration&.parsed_credentials&.dig('api_token') %>"
               placeholder="xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
               class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
               data-integration-setup-target="field"
               data-field="api_token">
      </div>
    </div>

    <!-- Connection Test -->
    <div class="mb-8">
      <button type="button"
              class="w-full py-3 px-4 bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium rounded-xl transition-colors flex items-center justify-center"
              data-action="click->integration-setup#testConnection"
              data-integration-setup-type-param="zendesk">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
        </svg>
        Test Connection
      </button>
      <div id="connection-result" class="mt-4"></div>
    </div>

    <div class="flex justify-between">
      <button type="submit" name="skip" value="1" class="text-gray-500 hover:text-gray-700 font-medium px-4 py-2 transition-colors">
        Skip for now
      </button>
      <button type="submit" class="btn-primary px-6 py-2.5">
        Continue
        <svg class="w-4 h-4 ml-2 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </button>
    </div>
  <% end %>
</div>
