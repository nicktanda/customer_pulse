<div>
  <div class="flex items-center mb-6">
    <div class="w-12 h-12 bg-gradient-to-br from-pink-500 to-rose-600 rounded-xl flex items-center justify-center mr-4">
      <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
      </svg>
    </div>
    <div>
      <h2 class="text-2xl font-bold text-gray-900">Email Recipients</h2>
      <p class="text-gray-500">Who should receive daily pulse reports?</p>
    </div>
    <span class="ml-auto px-3 py-1 bg-gray-100 text-gray-600 text-sm font-medium rounded-full">Optional</span>
  </div>

  <div class="bg-pink-50 border border-pink-200 rounded-xl p-4 mb-6">
    <div class="flex">
      <svg class="w-5 h-5 text-pink-600 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <div>
        <h4 class="font-medium text-pink-800 mb-1">Daily Pulse Reports</h4>
        <p class="text-sm text-pink-700">
          Customer Pulse will send daily summary emails to these recipients with key feedback insights,
          priority items, and trends. You can add or remove recipients later from the Recipients page.
        </p>
      </div>
    </div>
  </div>

  <% if @recipients&.any? %>
    <div class="mb-6">
      <h4 class="text-sm font-medium text-gray-700 mb-2">Current Recipients</h4>
      <div class="flex flex-wrap gap-2">
        <% @recipients.each do |recipient| %>
          <span class="inline-flex items-center px-3 py-1 bg-gray-100 text-gray-700 rounded-full text-sm">
            <%= recipient.email %>
          </span>
        <% end %>
      </div>
    </div>
  <% end %>

  <%= form_with url: update_step_onboarding_path, method: :post, data: { turbo_frame: "_top" }, local: true do |f| %>
    <%= hidden_field_tag :step, "recipients" %>

    <div class="space-y-4 mb-6">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Email Addresses (comma-separated)</label>
        <textarea name="emails"
                  rows="3"
                  placeholder="pm@company.com, cto@company.com, support-lead@company.com"
                  class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"></textarea>
        <p class="text-xs text-gray-500 mt-1">Enter email addresses separated by commas</p>
      </div>
    </div>

    <div class="flex justify-between">
      <button type="submit" name="skip" value="1" class="text-gray-500 hover:text-gray-700 font-medium px-4 py-2 transition-colors">
        Skip for now
      </button>
      <button type="submit" class="btn-primary px-6 py-2.5">
        Continue
        <svg class="w-4 h-4 ml-2 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </button>
    </div>
  <% end %>
</div>
