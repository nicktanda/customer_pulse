<div data-controller="integration-setup">
  <div class="flex items-center mb-6">
    <div class="w-12 h-12 bg-gradient-to-br from-purple-500 to-pink-600 rounded-xl flex items-center justify-center mr-4">
      <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="currentColor">
        <path d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zM6.313 15.165a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313zM8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zM8.834 6.313a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312zM18.956 8.834a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zM17.688 8.834a2.528 2.528 0 0 1-2.523 2.521 2.527 2.527 0 0 1-2.52-2.521V2.522A2.527 2.527 0 0 1 15.165 0a2.528 2.528 0 0 1 2.523 2.522v6.312zM15.165 18.956a2.528 2.528 0 0 1 2.523 2.522A2.528 2.528 0 0 1 15.165 24a2.527 2.527 0 0 1-2.52-2.522v-2.522h2.52zM15.165 17.688a2.527 2.527 0 0 1-2.52-2.523 2.526 2.526 0 0 1 2.52-2.52h6.313A2.527 2.527 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.523h-6.313z"/>
      </svg>
    </div>
    <div>
      <h2 class="text-2xl font-bold text-gray-900">Slack Integration</h2>
      <p class="text-gray-500">Capture feedback from Slack channels</p>
    </div>
    <span class="ml-auto px-3 py-1 bg-gray-100 text-gray-600 text-sm font-medium rounded-full">Optional</span>
  </div>

  <div class="bg-purple-50 border border-purple-200 rounded-xl p-4 mb-6">
    <div class="flex">
      <svg class="w-5 h-5 text-purple-600 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <div>
        <h4 class="font-medium text-purple-800 mb-1">How to set up Slack</h4>
        <ol class="text-sm text-purple-700 space-y-1 list-decimal list-inside">
          <li>Go to <a href="https://api.slack.com/apps" target="_blank" class="underline hover:text-purple-900">api.slack.com/apps</a> and create a new app</li>
          <li>Under "OAuth & Permissions", add scopes: <code class="bg-purple-100 px-1 rounded">channels:history</code>, <code class="bg-purple-100 px-1 rounded">channels:read</code></li>
          <li>Install the app to your workspace</li>
          <li>Copy the "Bot User OAuth Token" (starts with xoxb-)</li>
          <li>Invite the bot to channels you want to monitor</li>
        </ol>
      </div>
    </div>
  </div>

  <%= form_with url: update_step_onboarding_path, method: :post, data: { turbo_frame: "_top" }, local: true do |f| %>
    <%= hidden_field_tag :step, "slack" %>

    <div class="space-y-4 mb-6">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Bot Token</label>
        <input type="password"
               name="integration[bot_token]"
               value="<%= @integration&.parsed_credentials&.dig('bot_token') %>"
               placeholder="xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx"
               class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
               data-integration-setup-target="field"
               data-field="bot_token">
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Channel IDs (comma-separated)</label>
        <input type="text"
               name="integration[channels]"
               value="<%= @integration&.parsed_credentials&.dig('channels')&.join(', ') %>"
               placeholder="C01234567, C89012345"
               class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
               data-integration-setup-target="field"
               data-field="channels">
        <p class="text-xs text-gray-500 mt-1">Find channel IDs by right-clicking a channel and selecting "Copy link"</p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Keywords (comma-separated)</label>
        <input type="text"
               name="integration[keywords]"
               value="<%= @integration&.parsed_credentials&.dig('keywords')&.join(', ') %>"
               placeholder="feedback, bug, issue, feature request"
               class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
               data-integration-setup-target="field"
               data-field="keywords">
        <p class="text-xs text-gray-500 mt-1">Only messages containing these keywords will be captured</p>
      </div>
    </div>

    <!-- Connection Test -->
    <div class="mb-8">
      <button type="button"
              class="w-full py-3 px-4 bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium rounded-xl transition-colors flex items-center justify-center"
              data-action="click->integration-setup#testConnection"
              data-integration-setup-type-param="slack">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
        </svg>
        Test Connection
      </button>
      <div id="connection-result" class="mt-4"></div>
    </div>

    <div class="flex justify-between">
      <button type="submit" name="skip" value="1" class="text-gray-500 hover:text-gray-700 font-medium px-4 py-2 transition-colors">
        Skip for now
      </button>
      <button type="submit" class="btn-primary px-6 py-2.5">
        Continue
        <svg class="w-4 h-4 ml-2 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </button>
    </div>
  <% end %>
</div>
