<div data-controller="integration-setup">
  <div class="flex items-center mb-6">
    <div class="w-12 h-12 bg-gradient-to-br from-purple-500 to-violet-600 rounded-xl flex items-center justify-center mr-4">
      <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="currentColor">
        <path d="M13.91 2.216c-.373-.646-1.447-.646-1.82 0l-2.03 3.516c.395.227.752.506 1.058.829l1.982-3.431 7.734 13.392h-3.96c0 .478-.058.942-.166 1.386h5.54c.746 0 1.215-.813.842-1.458L13.91 2.216zm-5.88 5.088l-5.187 8.983a.972.972 0 00.841 1.458h6.226a4.463 4.463 0 01-.168-1.386H4.758l4.443-7.694a4.398 4.398 0 01-1.17-.36z"/>
        <circle cx="12" cy="15" r="3.5"/>
      </svg>
    </div>
    <div>
      <h2 class="text-2xl font-bold text-gray-900">Sentry Integration</h2>
      <p class="text-gray-500">Import error issues and user feedback</p>
    </div>
    <span class="ml-auto px-3 py-1 bg-gray-100 text-gray-600 text-sm font-medium rounded-full">Optional</span>
  </div>

  <div class="bg-purple-50 border border-purple-200 rounded-xl p-4 mb-6">
    <div class="flex">
      <svg class="w-5 h-5 text-purple-600 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <div>
        <h4 class="font-medium text-purple-800 mb-1">How to set up Sentry</h4>
        <ol class="text-sm text-purple-700 space-y-1 list-decimal list-inside">
          <li>Go to Settings > API Keys in your Sentry account</li>
          <li>Create a new API token with read permissions</li>
          <li>Copy your organization slug from the URL (e.g., yourorg.sentry.io)</li>
          <li>Optionally specify project slugs to monitor specific projects</li>
        </ol>
      </div>
    </div>
  </div>

  <%= form_with url: update_step_onboarding_path, method: :post, data: { turbo_frame: "_top" }, local: true do |f| %>
    <%= hidden_field_tag :step, "sentry" %>

    <div class="space-y-4 mb-6">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Auth Token</label>
        <input type="password"
               name="integration[auth_token]"
               value="<%= @integration&.parsed_credentials&.dig('auth_token') %>"
               placeholder="sntrys_..."
               class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
               data-integration-setup-target="field"
               data-field="auth_token">
        <p class="text-xs text-gray-500 mt-1">Your Sentry API auth token</p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Organization Slug</label>
        <input type="text"
               name="integration[organization_slug]"
               value="<%= @integration&.parsed_credentials&.dig('organization_slug') %>"
               placeholder="my-organization"
               class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
               data-integration-setup-target="field"
               data-field="organization_slug">
        <p class="text-xs text-gray-500 mt-1">Found in your Sentry URL: <code>https://[organization_slug].sentry.io</code></p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Project Slugs (Optional)</label>
        <input type="text"
               name="integration[project_slugs]"
               value="<%= @integration&.parsed_credentials&.dig('project_slugs') %>"
               placeholder="frontend, backend, mobile"
               class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
               data-integration-setup-target="field"
               data-field="project_slugs">
        <p class="text-xs text-gray-500 mt-1">Comma-separated list of projects to monitor. Leave blank for all projects.</p>
      </div>
    </div>

    <!-- Connection Test -->
    <div class="mb-8">
      <button type="button"
              class="w-full py-3 px-4 bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium rounded-xl transition-colors flex items-center justify-center"
              data-action="click->integration-setup#testConnection"
              data-integration-setup-type-param="sentry">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
        </svg>
        Test Connection
      </button>
      <div id="connection-result" class="mt-4"></div>
    </div>

    <div class="flex justify-between">
      <button type="submit" name="skip" value="1" class="text-gray-500 hover:text-gray-700 font-medium px-4 py-2 transition-colors">
        Skip for now
      </button>
      <button type="submit" class="btn-primary px-6 py-2.5">
        Continue
        <svg class="w-4 h-4 ml-2 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </button>
    </div>
  <% end %>
</div>
