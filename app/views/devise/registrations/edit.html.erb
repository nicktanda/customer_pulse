<% content_for :title, "Account Settings - Customer Pulse" %>

<div class="mb-8">
  <h1 class="text-3xl font-bold text-gray-900">Account Settings</h1>
  <p class="mt-2 text-gray-500">Manage your account information and security</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- Main Settings -->
  <div class="lg:col-span-2 space-y-6">
    <!-- Profile Information -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50">
        <h2 class="text-lg font-semibold text-gray-900">Profile Information</h2>
      </div>
      <div class="p-6">
        <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-6" }) do |f| %>
          <%= render "devise/shared/error_messages", resource: resource %>

          <div>
            <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
            <%= f.text_field :name, autofocus: true, autocomplete: "name", class: "form-input-enhanced text-sm py-2.5" %>
          </div>

          <div>
            <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
            <%= f.email_field :email, autocomplete: "email", class: "form-input-enhanced text-sm py-2.5" %>
            <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
              <p class="mt-2 text-sm text-amber-600 flex items-center">
                <svg class="h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                Waiting confirmation for: <%= resource.unconfirmed_email %>
              </p>
            <% end %>
          </div>

          <div class="border-t border-gray-100 pt-6">
            <h3 class="text-sm font-medium text-gray-900 mb-4">Change Password</h3>
            <p class="text-xs text-gray-500 mb-4">Leave blank if you don't want to change it</p>

            <div class="space-y-4">
              <div>
                <%= f.label :password, "New password", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
                <%= f.password_field :password, autocomplete: "new-password", placeholder: "New password", class: "form-input-enhanced text-sm py-2.5" %>
                <% if @minimum_password_length %>
                  <p class="mt-1 text-xs text-gray-400"><%= @minimum_password_length %> characters minimum</p>
                <% end %>
              </div>

              <div>
                <%= f.label :password_confirmation, "Confirm new password", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
                <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "Confirm new password", class: "form-input-enhanced text-sm py-2.5" %>
              </div>
            </div>
          </div>

          <div class="border-t border-gray-100 pt-6">
            <div>
              <%= f.label :current_password, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
              <p class="text-xs text-gray-500 mb-2">We need your current password to confirm changes</p>
              <%= f.password_field :current_password, autocomplete: "current-password", placeholder: "Current password", class: "form-input-enhanced text-sm py-2.5" %>
            </div>
          </div>

          <div class="flex justify-end">
            <%= f.submit "Save changes", class: "btn-primary text-sm cursor-pointer" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Sidebar -->
  <div class="space-y-6">
    <!-- Danger Zone -->
    <div class="bg-white rounded-xl shadow-sm border border-red-100 overflow-hidden">
      <div class="px-6 py-4 border-b border-red-100 bg-red-50/50">
        <h2 class="text-lg font-semibold text-red-900">Danger Zone</h2>
      </div>
      <div class="p-6">
        <p class="text-sm text-gray-600 mb-4">
          Once you delete your account, there is no going back. Please be certain.
        </p>
        <%= button_to "Delete my account", registration_path(resource_name),
            method: :delete,
            data: { confirm: "Are you sure you want to delete your account? This action cannot be undone.", turbo_confirm: "Are you sure you want to delete your account? This action cannot be undone." },
            class: "w-full bg-red-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-red-700 active:scale-[0.98] transition-all text-sm" %>
      </div>
    </div>

    <!-- Back link -->
    <div class="text-center">
      <%= link_to root_path, class: "inline-flex items-center text-sm text-gray-500 hover:text-indigo-600 transition-colors" do %>
        <svg class="h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Back to Dashboard
      <% end %>
    </div>
  </div>
</div>
