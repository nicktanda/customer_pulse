<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-indigo-50 via-white to-purple-50 py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full">
    <!-- Logo and Header -->
    <div class="text-center mb-8">
      <div class="mx-auto w-16 h-16 bg-gradient-to-br from-indigo-600 to-purple-600 rounded-2xl flex items-center justify-center shadow-lg mb-4">
        <svg class="h-9 w-9 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
        </svg>
      </div>
      <h2 class="text-3xl font-bold text-gray-900">Welcome back</h2>
      <p class="mt-2 text-gray-500">Sign in to Customer Pulse</p>
    </div>

    <!-- Login Card -->
    <div class="bg-white rounded-2xl shadow-xl border border-gray-100 p-8">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-6" }) do |f| %>
        <div>
          <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "you@example.com", class: "form-input-enhanced text-sm py-2.5" %>
        </div>

        <div>
          <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.password_field :password, autocomplete: "current-password", placeholder: "Enter your password", class: "form-input-enhanced text-sm py-2.5" %>
        </div>

        <div class="flex items-center justify-between">
          <% if devise_mapping.rememberable? %>
            <div class="flex items-center">
              <%= f.check_box :remember_me, class: "h-4 w-4 text-indigo-600 border-gray-300 rounded focus:ring-indigo-500" %>
              <%= f.label :remember_me, class: "ml-2 text-sm text-gray-600" %>
            </div>
          <% end %>

          <%- if devise_mapping.recoverable? && controller_name != 'passwords' %>
            <%= link_to "Forgot password?", new_password_path(resource_name), class: "text-sm font-medium text-indigo-600 hover:text-indigo-500 transition-colors" %>
          <% end %>
        </div>

        <div>
          <%= f.submit "Sign in", class: "w-full btn-primary py-2.5 text-sm cursor-pointer" %>
        </div>
      <% end %>

      <%- if devise_mapping.registerable? %>
        <div class="mt-6 text-center">
          <p class="text-sm text-gray-500">
            Don't have an account?
            <%= link_to "Sign up", new_registration_path(resource_name), class: "font-medium text-indigo-600 hover:text-indigo-500 transition-colors" %>
          </p>
        </div>
      <% end %>
    </div>
  </div>
</div>
