<% content_for :title, "Feedback - Customer Pulse" %>

<div data-controller="polling"
     data-polling-interval-value="30000"
     data-polling-sync-url-value="<%= sync_all_integrations_path %>">
</div>

<div class="mb-6 flex justify-between items-center">
  <div>
    <h1 class="text-3xl font-bold text-gray-900">Feedback</h1>
    <p class="mt-1 text-gray-500">Browse and manage customer feedback</p>
  </div>
  <div>
    <button type="button"
            class="btn-secondary inline-flex items-center gap-2"
            data-controller="sync-button"
            data-sync-button-url-value="<%= sync_all_integrations_path %>"
            data-action="click->sync-button#sync">
      <svg class="w-4 h-4" data-sync-button-target="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
      </svg>
      <span data-sync-button-target="text">Sync All</span>
    </button>
  </div>
</div>

<!-- Filters -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 mb-6">
  <div class="p-5">
    <%= form_with url: feedback_index_path, method: :get, class: "flex flex-col lg:flex-row lg:items-end gap-4" do |f| %>
      <div class="flex-1 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1.5">Search</label>
          <%= f.text_field :q, value: params[:q], placeholder: "Search feedback...", class: "form-input-enhanced text-sm py-2" %>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1.5">Source</label>
          <%= f.select :source, options_for_select([["All Sources", ""]] + Feedback.sources.keys.map { |s| [s.titleize.gsub('_', ' '), s] }, params[:source]), {}, class: "form-input-enhanced text-sm py-2" %>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1.5">Category</label>
          <%= f.select :category, options_for_select([["All Categories", ""]] + Feedback.categories.keys.map { |c| [c.titleize.gsub('_', ' '), c] }, params[:category]), {}, class: "form-input-enhanced text-sm py-2" %>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1.5">Priority</label>
          <%= f.select :priority, options_for_select([["All Priorities", ""], ["P1 - Critical", "p1"], ["P2 - High", "p2"], ["P3 - Medium", "p3"], ["P4 - Low", "p4"], ["Unset", "unset"]], params[:priority]), {}, class: "form-input-enhanced text-sm py-2" %>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1.5">Status</label>
          <%= f.select :status, options_for_select([["All Statuses", ""]] + Feedback.statuses.keys.map { |s| [s.titleize.gsub('_', ' '), s] }, params[:status]), {}, class: "form-input-enhanced text-sm py-2" %>
        </div>
      </div>
      <div class="flex gap-2 lg:ml-4">
        <%= f.submit "Filter", class: "btn-primary text-sm cursor-pointer" %>
        <% if params[:q].present? || params[:source].present? || params[:category].present? || params[:priority].present? || params[:status].present? %>
          <%= link_to "Clear", feedback_index_path, class: "btn-secondary text-sm" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<!-- Feedback Table -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200 table-zebra">
      <thead>
        <tr class="bg-gray-50/80">
          <th class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Source</th>
          <th class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Title / Content</th>
          <th class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Category</th>
          <th class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Priority</th>
          <th class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
          <th class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Date</th>
        </tr>
      </thead>
      <tbody id="feedback_list" class="divide-y divide-gray-100">
        <% if @feedbacks.any? %>
          <% @feedbacks.each do |feedback| %>
            <%= render "feedback/feedback_row", feedback: feedback %>
          <% end %>
        <% else %>
          <tr>
            <td colspan="6" class="px-6 py-16 text-center">
              <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/>
              </svg>
              <h3 class="mt-3 text-sm font-medium text-gray-900">No feedback found</h3>
              <p class="mt-1 text-sm text-gray-500">Try adjusting your filters or search criteria.</p>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<!-- Pagination -->
<% if @pagy.pages > 1 %>
  <div class="mt-6">
    <nav class="pagy">
      <%== pagy_nav(@pagy) %>
    </nav>
  </div>
<% end %>
