<% content_for :title, "#{@feedback.title || 'Feedback'} - Customer Pulse" %>

<div class="mb-6">
  <%= link_to feedback_index_path, class: "inline-flex items-center text-indigo-600 hover:text-indigo-800 text-sm font-medium group transition-colors" do %>
    <svg class="h-4 w-4 mr-1.5 group-hover:-translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Back to Feedback
  <% end %>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- Main Content -->
  <div class="lg:col-span-2 space-y-6">
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="px-6 py-5 border-b border-gray-100 bg-gradient-to-r from-indigo-50/50 to-purple-50/50">
        <div class="flex items-start justify-between">
          <div>
            <h1 class="text-xl font-bold text-gray-900">
              <%= @feedback.title || "Feedback ##{@feedback.id}" %>
            </h1>
            <div class="mt-2 flex flex-wrap items-center gap-2 text-sm text-gray-500">
              <span class="inline-flex items-center px-2.5 py-1 rounded-full bg-white/80 text-gray-700 text-xs font-medium shadow-sm">
                <%= @feedback.source_label %>
              </span>
              <span class="text-gray-300">&bull;</span>
              <span><%= @feedback.created_at.strftime("%B %d, %Y at %H:%M") %></span>
            </div>
          </div>
          <div class="flex flex-wrap gap-2">
            <span class="inline-flex items-center px-2.5 py-1 text-xs font-semibold rounded-full <%= priority_badge_class(@feedback.priority) %>">
              <%= @feedback.priority_label %>
            </span>
            <span class="inline-flex items-center px-2.5 py-1 text-xs font-medium rounded-full <%= category_badge_class(@feedback.category) %>">
              <%= @feedback.category_label %>
            </span>
          </div>
        </div>
      </div>

      <div class="px-6 py-5">
        <h3 class="text-sm font-semibold text-gray-700 mb-3">Content</h3>
        <div class="prose max-w-none text-gray-600 leading-relaxed">
          <%= simple_format(@feedback.content) %>
        </div>
      </div>

      <% if @feedback.author_name.present? || @feedback.author_email.present? %>
        <div class="px-6 py-4 border-t border-gray-100 bg-gray-50/50">
          <h3 class="text-sm font-semibold text-gray-700 mb-2">Author</h3>
          <div class="flex items-center">
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-indigo-400 to-purple-500 flex items-center justify-center text-white text-sm font-medium">
              <%= (@feedback.author_name || @feedback.author_email || "?").first.upcase %>
            </div>
            <div class="ml-3">
              <p class="text-sm font-medium text-gray-900"><%= @feedback.author_name %></p>
              <% if @feedback.author_email.present? %>
                <p class="text-xs text-gray-500"><%= @feedback.author_email %></p>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <% if @feedback.ai_summary.present? %>
      <div class="bg-white rounded-xl shadow-sm overflow-hidden ai-analysis-card">
        <div class="px-6 py-4 border-b border-indigo-100 bg-gradient-to-r from-indigo-50 to-purple-50">
          <h2 class="text-lg font-semibold text-gray-900 flex items-center">
            <div class="p-2 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-lg mr-3 shadow-sm">
              <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
              </svg>
            </div>
            AI Analysis
          </h2>
        </div>
        <div class="px-6 py-5">
          <p class="text-gray-600 leading-relaxed"><%= @feedback.ai_summary %></p>
          <% if @feedback.ai_confidence_score.present? %>
            <div class="mt-5 p-4 bg-gray-50 rounded-lg">
              <div class="flex items-center justify-between mb-2">
                <span class="text-sm font-medium text-gray-700">Confidence Score</span>
                <span class="text-sm font-bold text-indigo-600"><%= (@feedback.ai_confidence_score * 100).round %>%</span>
              </div>
              <div class="h-2.5 bg-gray-200 rounded-full overflow-hidden">
                <div class="confidence-bar-fill" style="width: <%= (@feedback.ai_confidence_score * 100).round %>%"></div>
              </div>
            </div>
          <% end %>
          <% if @feedback.ai_processed_at.present? %>
            <p class="mt-4 text-xs text-gray-400 flex items-center">
              <svg class="h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              Processed <%= time_ago_in_words(@feedback.ai_processed_at) %> ago
            </p>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if @feedback.raw_data.present? %>
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100">
          <h2 class="text-lg font-semibold text-gray-900">Raw Data</h2>
        </div>
        <div class="px-6 py-4">
          <pre class="text-xs bg-gray-900 text-gray-100 p-4 rounded-lg overflow-x-auto font-mono"><%= JSON.pretty_generate(@feedback.raw_data) %></pre>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Sidebar -->
  <div class="space-y-6">
    <!-- Status & Actions -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50">
        <h2 class="text-lg font-semibold text-gray-900">Status & Actions</h2>
      </div>
      <div class="px-6 py-5 space-y-5">
        <%= form_with model: @feedback, url: override_feedback_path(@feedback), method: :patch, class: "space-y-4" do |f| %>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Status</label>
            <%= f.select :status, Feedback.statuses.keys.map { |s| [s.titleize.gsub('_', ' '), s] }, {}, class: "form-input-enhanced text-sm" %>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Priority</label>
            <%= f.select :priority, [["Unset", "unset"], ["P1 - Critical", "p1"], ["P2 - High", "p2"], ["P3 - Medium", "p3"], ["P4 - Low", "p4"]], {}, class: "form-input-enhanced text-sm" %>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Category</label>
            <%= f.select :category, Feedback.categories.keys.map { |c| [c.titleize.gsub('_', ' '), c] }, {}, class: "form-input-enhanced text-sm" %>
          </div>

          <%= f.submit "Update", class: "w-full btn-primary text-sm cursor-pointer" %>
        <% end %>

        <div class="border-t border-gray-100 pt-4">
          <%= button_to reprocess_feedback_path(@feedback), method: :post, class: "w-full btn-secondary text-sm flex items-center justify-center" do %>
            <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
            Reprocess with AI
          <% end %>
        </div>
      </div>
    </div>

    <!-- Metadata -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50">
        <h2 class="text-lg font-semibold text-gray-900">Details</h2>
      </div>
      <div class="px-6 py-4 space-y-3 text-sm">
        <div class="flex justify-between items-center py-2 border-b border-gray-50">
          <span class="text-gray-500">ID</span>
          <span class="font-mono text-gray-900 bg-gray-100 px-2 py-0.5 rounded">#<%= @feedback.id %></span>
        </div>
        <div class="flex justify-between items-center py-2 border-b border-gray-50">
          <span class="text-gray-500">Source ID</span>
          <span class="text-gray-900 truncate max-w-[150px] font-mono text-xs" title="<%= @feedback.source_external_id %>">
            <%= @feedback.source_external_id || "N/A" %>
          </span>
        </div>
        <div class="flex justify-between items-center py-2 border-b border-gray-50">
          <span class="text-gray-500">Created</span>
          <span class="text-gray-900"><%= @feedback.created_at.strftime("%b %d, %Y %H:%M") %></span>
        </div>
        <div class="flex justify-between items-center py-2 border-b border-gray-50">
          <span class="text-gray-500">Updated</span>
          <span class="text-gray-900"><%= @feedback.updated_at.strftime("%b %d, %Y %H:%M") %></span>
        </div>
        <div class="flex justify-between items-center py-2">
          <span class="text-gray-500">Manually Reviewed</span>
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium <%= @feedback.manually_reviewed ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-600' %>">
            <%= @feedback.manually_reviewed ? "Yes" : "No" %>
          </span>
        </div>
      </div>
    </div>
  </div>
</div>
