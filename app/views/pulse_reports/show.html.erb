<% content_for :title, "Pulse Report - Customer Pulse" %>

<% if @has_pending_prs %>
  <div data-controller="polling" data-polling-interval-value="3000" class="hidden"></div>
<% end %>

<div class="mb-6">
  <%= link_to pulse_reports_path, class: "text-indigo-600 hover:text-indigo-800 text-sm flex items-center" do %>
    <svg class="h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Back to Reports
  <% end %>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2 space-y-6">
    <div class="bg-white rounded-lg shadow">
      <div class="px-6 py-4 border-b border-gray-200">
        <div class="flex items-center justify-between">
          <h1 class="text-xl font-semibold text-gray-900">
            Pulse Report: <%= @report.period_start.strftime("%B %d") %> - <%= @report.period_end.strftime("%B %d, %Y") %>
          </h1>
          <span class="px-3 py-1 text-sm font-medium rounded <%= @report.sent? ? 'bg-green-100 text-green-800' : 'bg-yellow-100 text-yellow-800' %>">
            <%= @report.sent? ? 'Sent' : 'Pending' %>
          </span>
        </div>
      </div>

      <div class="px-6 py-4">
        <div class="grid grid-cols-3 gap-4 mb-6">
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-2xl font-bold text-indigo-600"><%= @report.feedback_count %></div>
            <div class="text-sm text-gray-500">Feedback Items</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-2xl font-bold text-indigo-600"><%= @report.recipient_count %></div>
            <div class="text-sm text-gray-500">Recipients</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-2xl font-bold text-indigo-600"><%= @report.sent_at ? @report.sent_at.strftime("%H:%M") : "-" %></div>
            <div class="text-sm text-gray-500">Sent At</div>
          </div>
        </div>

        <% if @report.summary.present? %>
          <div class="mb-6">
            <h3 class="text-sm font-medium text-gray-700 mb-2">Summary</h3>
            <div class="bg-gray-50 rounded-lg p-4">
              <%= simple_format(@report.summary) %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900">Feedback in this Report</h2>
      </div>
      <div class="divide-y divide-gray-200">
        <% if @feedbacks.any? %>
          <% @feedbacks.limit(20).each do |feedback| %>
            <%= link_to feedback_path(feedback), class: "block px-6 py-4 hover:bg-gray-50" do %>
              <div class="flex items-start justify-between">
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-medium text-gray-900 truncate">
                    <%= feedback.title || feedback.content.truncate(60) %>
                  </p>
                  <p class="text-xs text-gray-500 mt-1">
                    <%= feedback.source_label %> &bull; <%= feedback.category_label %>
                  </p>
                </div>
                <div class="ml-2 flex space-x-2">
                  <span class="px-2 py-1 text-xs font-medium rounded <%= priority_badge_class(feedback.priority) %>">
                    <%= feedback.priority_label %>
                  </span>
                </div>
              </div>
            <% end %>
          <% end %>
          <% if @feedbacks.count > 20 %>
            <div class="px-6 py-4 text-center text-sm text-gray-500">
              And <%= @feedbacks.count - 20 %> more...
            </div>
          <% end %>
        <% else %>
          <div class="px-6 py-8 text-center text-gray-500">
            No feedback in this period
          </div>
        <% end %>
      </div>
    </div>

    <% if @quick_wins.any? || @high_impact.any? %>
      <div class="bg-gradient-to-br from-green-50 to-emerald-50 rounded-lg shadow border border-green-200" data-controller="pr-auto-open">
        <div class="px-6 py-4 border-b border-green-200 flex items-center justify-between">
          <h2 class="text-lg font-semibold text-green-800 flex items-center">
            <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
            </svg>
            Recommended Actions
          </h2>
          <% unless @github_integration %>
            <span class="text-xs text-green-700">
              <%= link_to "Connect GitHub", onboarding_path, class: "underline hover:text-green-900" %> to generate PRs
            </span>
          <% end %>
        </div>
        <div class="px-6 py-4 space-y-6">
          <% if @quick_wins.any? %>
            <div>
              <h3 class="text-sm font-semibold text-green-700 mb-3 flex items-center">
                <span class="w-2 h-2 bg-green-500 rounded-full mr-2"></span>
                Quick Wins
              </h3>
              <div class="space-y-3">
                <% @quick_wins.each do |idea| %>
                  <div class="bg-white rounded-lg p-4 border-l-4 border-green-500 shadow-sm">
                    <div class="flex items-start justify-between">
                      <h4 class="font-medium text-gray-900"><%= idea.title %></h4>
                      <div class="flex items-center space-x-2">
                        <span class="px-2 py-0.5 text-xs font-medium bg-green-100 text-green-800 rounded">
                          Low Effort
                        </span>
                        <%= render partial: "pulse_reports/pr_button", locals: { idea: idea, github_integration: @github_integration } %>
                      </div>
                    </div>
                    <p class="text-sm text-gray-600 mt-1"><%= truncate(idea.description, length: 150) %></p>
                    <% if idea.rationale.present? %>
                      <p class="text-xs text-gray-500 mt-2 italic">Why: <%= truncate(idea.rationale, length: 100) %></p>
                    <% end %>
                    <%= render partial: "pulse_reports/pr_status", locals: { idea: idea } %>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>

          <% if @high_impact.any? %>
            <div>
              <h3 class="text-sm font-semibold text-indigo-700 mb-3 flex items-center">
                <span class="w-2 h-2 bg-indigo-500 rounded-full mr-2"></span>
                High Impact Features
              </h3>
              <div class="space-y-3">
                <% @high_impact.each do |idea| %>
                  <div class="bg-white rounded-lg p-4 border-l-4 border-indigo-500 shadow-sm">
                    <div class="flex items-start justify-between">
                      <h4 class="font-medium text-gray-900"><%= idea.title %></h4>
                      <div class="flex items-center space-x-2">
                        <span class="px-2 py-0.5 text-xs font-medium bg-indigo-100 text-indigo-800 rounded">
                          <%= idea.impact_label %> Impact
                        </span>
                        <%= render partial: "pulse_reports/pr_button", locals: { idea: idea, github_integration: @github_integration } %>
                      </div>
                    </div>
                    <p class="text-sm text-gray-600 mt-1"><%= truncate(idea.description, length: 150) %></p>
                    <% if idea.rationale.present? %>
                      <p class="text-xs text-gray-500 mt-2 italic">Why: <%= truncate(idea.rationale, length: 100) %></p>
                    <% end %>
                    <%= render partial: "pulse_reports/pr_status", locals: { idea: idea } %>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if @insights.any? %>
      <div class="bg-white rounded-lg shadow">
        <div class="px-6 py-4 border-b border-gray-200">
          <h2 class="text-lg font-semibold text-gray-900 flex items-center">
            <svg class="h-5 w-5 mr-2 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
            Key Insights
          </h2>
        </div>
        <div class="divide-y divide-gray-200">
          <% @insights.each do |insight| %>
            <div class="px-6 py-4">
              <div class="flex items-start justify-between">
                <div class="flex-1">
                  <div class="flex items-center space-x-2 mb-1">
                    <span class="px-2 py-0.5 text-xs font-medium rounded <%= insight.severity == 'critical' ? 'bg-red-100 text-red-800' : (insight.severity == 'major' ? 'bg-yellow-100 text-yellow-800' : 'bg-blue-100 text-blue-800') %>">
                      <%= insight.severity_label %>
                    </span>
                    <span class="px-2 py-0.5 text-xs font-medium bg-gray-100 text-gray-700 rounded">
                      <%= insight.type_label %>
                    </span>
                  </div>
                  <h3 class="font-medium text-gray-900"><%= insight.title %></h3>
                  <p class="text-sm text-gray-600 mt-1"><%= truncate(insight.description, length: 200) %></p>
                  <div class="flex items-center space-x-4 mt-2 text-xs text-gray-500">
                    <span><%= insight.feedback_count %> related feedback items</span>
                    <span><%= insight.confidence_score %>% confidence</span>
                  </div>
                </div>
              </div>
              <% if insight.ideas.any? %>
                <div class="mt-3 pl-4 border-l-2 border-indigo-200">
                  <p class="text-xs font-medium text-indigo-600 mb-1">Related Ideas:</p>
                  <ul class="text-sm text-gray-600 space-y-1">
                    <% insight.ideas.limit(3).each do |idea| %>
                      <li class="flex items-center">
                        <span class="w-1.5 h-1.5 bg-indigo-400 rounded-full mr-2"></span>
                        <%= idea.title %>
                      </li>
                    <% end %>
                  </ul>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="space-y-6">
    <div class="bg-white rounded-lg shadow">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900">Actions</h2>
      </div>
      <div class="px-6 py-4">
        <% if @report.sent? %>
          <%= button_to "Resend Report", resend_pulse_report_path(@report), method: :post, class: "w-full bg-indigo-600 text-white px-4 py-2 rounded-md hover:bg-indigo-700 text-sm font-medium" %>
        <% else %>
          <p class="text-sm text-gray-500">Report has not been sent yet.</p>
        <% end %>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900">Details</h2>
      </div>
      <div class="px-6 py-4 space-y-3 text-sm">
        <div class="flex justify-between">
          <span class="text-gray-500">ID</span>
          <span class="text-gray-900">#<%= @report.id %></span>
        </div>
        <div class="flex justify-between">
          <span class="text-gray-500">Period Start</span>
          <span class="text-gray-900"><%= @report.period_start.strftime("%b %d, %Y %H:%M") %></span>
        </div>
        <div class="flex justify-between">
          <span class="text-gray-500">Period End</span>
          <span class="text-gray-900"><%= @report.period_end.strftime("%b %d, %Y %H:%M") %></span>
        </div>
        <div class="flex justify-between">
          <span class="text-gray-500">Created</span>
          <span class="text-gray-900"><%= @report.created_at.strftime("%b %d, %Y %H:%M") %></span>
        </div>
      </div>
    </div>
  </div>
</div>
