<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Claude Code Skills</h1>
      <p class="mt-1 text-sm text-gray-500">Custom skills are synced to <code class="bg-gray-100 px-1 rounded">.claude/skills/</code> for Claude Code to use.</p>
    </div>
    <%= link_to new_skill_path, class: "btn-primary" do %>
      <svg class="w-5 h-5 mr-2 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      New Skill
    <% end %>
  </div>

  <% if @skills.any? %>
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      <% @skills.each do |skill| %>
        <div class="card hover:shadow-md transition-shadow">
          <div class="p-5">
            <div class="flex items-start justify-between">
              <div class="flex-1 min-w-0">
                <h3 class="text-lg font-semibold text-gray-900 truncate"><%= skill.title %></h3>
                <p class="text-sm text-gray-500 font-mono"><%= skill.name %></p>
              </div>
              <div class="flex items-center gap-2 ml-4">
                <%= link_to edit_skill_path(skill), class: "text-gray-400 hover:text-indigo-600" do %>
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                  </svg>
                <% end %>
                <%= button_to skill_path(skill), method: :delete, data: { turbo_confirm: "Delete skill '#{skill.title}'? This will also remove it from the filesystem." }, class: "text-gray-400 hover:text-red-600" do %>
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                  </svg>
                <% end %>
              </div>
            </div>

            <% if skill.description.present? %>
              <p class="mt-3 text-sm text-gray-600 line-clamp-2"><%= skill.description %></p>
            <% end %>

            <div class="mt-4 flex items-center justify-between text-xs text-gray-400">
              <span>By <%= skill.user.name || skill.user.email %></span>
              <span><%= time_ago_in_words(skill.updated_at) %> ago</span>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="card">
      <div class="p-12 text-center">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
        </svg>
        <h3 class="mt-4 text-lg font-medium text-gray-900">No custom skills yet</h3>
        <p class="mt-2 text-sm text-gray-500">Create your first skill to extend Claude Code's capabilities.</p>
        <div class="mt-6">
          <%= link_to "Create Skill", new_skill_path, class: "btn-primary" %>
        </div>
      </div>
    </div>
  <% end %>
</div>
