<div class="max-w-3xl mx-auto">
  <div class="mb-6">
    <%= link_to skills_path, class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700" do %>
      <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Back to Skills
    <% end %>
  </div>

  <div class="card">
    <div class="p-5 border-b border-gray-200">
      <div class="flex items-start justify-between">
        <div>
          <h1 class="text-xl font-bold text-gray-900"><%= @skill.title %></h1>
          <p class="mt-1 text-sm text-gray-500 font-mono"><%= @skill.name %></p>
        </div>
        <div class="flex items-center gap-2">
          <%= link_to edit_skill_path(@skill), class: "btn-secondary" do %>
            Edit
          <% end %>
        </div>
      </div>

      <% if @skill.description.present? %>
        <p class="mt-4 text-gray-600"><%= @skill.description %></p>
      <% end %>

      <div class="mt-4 flex items-center gap-4 text-sm text-gray-500">
        <span>Created by <%= @skill.user.name || @skill.user.email %></span>
        <span>Updated <%= time_ago_in_words(@skill.updated_at) %> ago</span>
      </div>
    </div>

    <div class="p-5">
      <h3 class="text-sm font-medium text-gray-700 mb-2">Skill Content</h3>
      <div class="bg-gray-50 rounded-lg p-4 font-mono text-sm whitespace-pre-wrap overflow-x-auto"><%= @skill.content %></div>
    </div>

    <div class="p-5 border-t border-gray-200 bg-gray-50">
      <h3 class="text-sm font-medium text-gray-700 mb-2">File Location</h3>
      <code class="text-sm text-gray-600"><%= @skill.skill_file_path.to_s.sub(Rails.root.to_s + '/', '') %></code>
    </div>
  </div>
</div>
