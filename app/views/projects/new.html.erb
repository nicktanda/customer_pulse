<div class="max-w-2xl mx-auto">
  <div class="mb-6">
    <%= link_to projects_path, class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700" do %>
      <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Back to Projects
    <% end %>
  </div>

  <div class="card">
    <div class="p-5 border-b border-gray-200">
      <h1 class="text-xl font-semibold text-gray-900">Create New Project</h1>
      <p class="mt-1 text-sm text-gray-500">Projects help you organize feedback and collaborate with your team.</p>
    </div>
    <div class="p-5">
      <%= render 'form', project: @project %>
    </div>
  </div>
</div>
