<%= form_with model: project, class: "space-y-6" do |f| %>
  <% if project.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <div class="flex">
        <svg class="h-5 w-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            <%= pluralize(project.errors.count, "error") %> prevented this project from being saved:
          </h3>
          <ul class="mt-2 text-sm text-red-700 list-disc list-inside">
            <% project.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name, class: "form-input-enhanced", placeholder: "My Project", autofocus: true %>
  </div>

  <div>
    <%= f.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :description, rows: 3, class: "form-input-enhanced", placeholder: "Optional description of this project..." %>
  </div>

  <div class="flex items-center justify-end gap-3 pt-4">
    <% if project.persisted? %>
      <%= link_to "Cancel", project, class: "btn-secondary" %>
    <% else %>
      <%= link_to "Cancel", projects_path, class: "btn-secondary" %>
    <% end %>
    <%= f.submit project.persisted? ? "Update Project" : "Create Project", class: "btn-primary cursor-pointer" %>
  </div>
<% end %>
