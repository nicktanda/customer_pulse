# See https://help.github.com/articles/ignoring-files for more about ignoring files.

# Environment files (repo root)
/.env*
# Real `.env` files anywhere (secrets live here). Templates use `.env.example`.
**/.env
!**/.env.example
# Local overrides in any workspace (never commit real secrets)
.env*.local

# macOS Finder metadata (per-folder view settings — not app source)
.DS_Store

# Logs and temp
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Dependencies in root and all Yarn workspaces (apps/web, apps/worker, packages/*)
node_modules

# Cursor IDE debug output (not project source)
.cursor/

# Next.js
/apps/web/.next
/apps/web/out
*.tsbuildinfo

# Worker build
/apps/worker/dist

# Drizzle generated SQL (optional to commit)
/packages/db/drizzle
