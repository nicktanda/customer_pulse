{
  "name": "customer_pulse",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "bcryptjs": "^3.0.3",
    "concurrently": "^9.1.2",
    "postgres": "^3.4.5",
    "yaml": "^2.7.0"
  },
  "scripts": {
    "dev": "concurrently -n web,worker -c blue,green \"yarn workspace web dev\" \"yarn workspace worker dev\"",
    "dev:web": "yarn workspace web dev",
    "dev:worker": "yarn workspace worker dev",
    "clean:web-next": "yarn workspace web clean",
    "build": "yarn build:web && yarn build:worker",
    "build:web": "yarn workspace web build",
    "build:worker": "yarn workspace worker build",
    "test": "yarn test:db && yarn test:web && yarn test:worker && yarn workspace worker build",
    "test:db": "yarn workspace @customer-pulse/db test",
    "test:web": "yarn workspace web test",
    "test:worker": "yarn workspace worker test",
    "bootstrap:dev-users": "node scripts/bootstrap-dev-user.mjs",
    "db:ensure-membership": "node --env-file=.env scripts/ensure-projects-membership-tables.mjs",
    "db:migrate": "cd packages/db && node --env-file=../../.env ../../node_modules/drizzle-kit/bin.cjs migrate",
    "db:migrate:cp": "cd packages/db && node --env-file=../../.env ../../node_modules/drizzle-kit/bin.cjs migrate --config=drizzle-control-plane.config.ts",
    "db:generate:cp": "yarn workspace @customer-pulse/db generate:cp",
    "db:generate:tenant": "yarn workspace @customer-pulse/db generate",
    "db:migrate:tenants": "node --env-file=.env scripts/migrate-all-tenants.ts",
    "setup:multi-tenant": "node --env-file=.env scripts/setup-multi-tenant-dev.mjs",
    "db:ensure-users-schema": "node scripts/ensure-users-schema.mjs",
    "document-skills": "node scripts/document-skills-and-agents.mjs",
    "ci:local": "yarn workspace web lint && yarn test && AUTH_SECRET='ci-test-secret-at-least-32-chars-long!!' NEXTAUTH_URL='http://localhost:3001' yarn build:web && node scripts/document-skills-and-agents.mjs --check",
    "ci:local:full": "yarn install --frozen-lockfile && yarn ci:local"
  }
}
