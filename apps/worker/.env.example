REDIS_URL=redis://127.0.0.1:6379/0

# Bull Board (http://localhost:3002/admin/queues)
BULL_BOARD_PORT=3002
BULL_BOARD_USER=admin
BULL_BOARD_PASS=change-me

# Same Postgres as the web app — workers read/write feedback, integrations, etc.
DATABASE_URL=postgres://localhost:5432/customer_pulse_development

# Must match the web app — used to decrypt integration credentials (Anthropic key, etc.) from the DB.
# Generate with: openssl rand -hex 32
LOCKBOX_MASTER_KEY=
