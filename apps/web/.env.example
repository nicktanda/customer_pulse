# Next.js app (`apps/web`) — copy to `apps/web/.env.local` for local dev.
# Point at your Postgres instance (can match production if you share one DB during cutover).

DATABASE_URL=postgres://localhost:5432/customer_pulse_development
REDIS_URL=redis://127.0.0.1:6379/0

# Auth.js — generate: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3001

# Optional Google OAuth (reuse an existing Google Cloud OAuth client if you already have one)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Required for API key lookup on `POST /api/v1/feedback` (encrypts stored API keys)
LOCKBOX_MASTER_KEY=

# Slack Events API / webhook signing (global secret)
SLACK_SIGNING_SECRET=

# Link to Bull Board on the worker (e.g. http://localhost:3002) — shown to admins only
NEXT_PUBLIC_BULL_BOARD_URL=http://localhost:3002

# Synthetic demo data button on Settings (admin only). Do not set in production unless you mean it.
# ALLOW_DEMO_DATA_SEED=true
