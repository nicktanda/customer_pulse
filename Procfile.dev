# -b 0.0.0.0: required for Docker (port publish); localhost-only would block hostâ†’container access.
web: env RUBY_DEBUG_OPEN=true bin/rails server -b 0.0.0.0
# --watch=forever: without this, esbuild exits when stdin is closed (e.g. Docker),
# which makes foreman kill web/worker/css too.
js: yarn build --watch=forever
css: yarn build:css --watch
worker: bundle exec sidekiq
