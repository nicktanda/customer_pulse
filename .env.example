# ===================
# Required
# ===================

# Database
DATABASE_URL=postgres://localhost:5432/customer_pulse_development

# Redis (for Sidekiq and caching)
REDIS_URL=redis://localhost:6379/0

# Encryption key for storing integration credentials
# Generate with: rails secret | head -c 64
LOCKBOX_MASTER_KEY=

# Rails secret key
# Generate with: rails secret
SECRET_KEY_BASE=

# ===================
# Email (Resend)
# ===================

# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=

# Use onboarding@resend.dev for testing (only sends to your verified email)
# Once you verify a domain, use something like noreply@yourdomain.com
MAILER_FROM_ADDRESS=onboarding@resend.dev

# ===================
# AI Processing
# ===================

# Anthropic API key for feedback classification
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ===================
# Integrations (optional)
# ===================

# Google Forms/Sheets - JSON credentials from Google Cloud Console
# GOOGLE_CREDENTIALS_JSON=

# Slack webhook signature verification
# SLACK_SIGNING_SECRET=

# Linear webhook signature verification
# LINEAR_WEBHOOK_SECRET=

# ===================
# Production only
# ===================

# Your production domain (used for links in emails)
# APP_HOST=yourdomain.com
