# ===================
# Required
# ===================

# Database
DATABASE_URL=postgres://localhost:5432/customer_pulse_development

# Redis (for BullMQ job queues)
REDIS_URL=redis://127.0.0.1:6379/0

# Encryption key for integration credentials stored in the DB
# Generate with: openssl rand -hex 32
LOCKBOX_MASTER_KEY=

# Auth.js session signing key (replaces Rails SECRET_KEY_BASE)
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Base URL for auth callbacks and email links
NEXTAUTH_URL=http://localhost:3001

# ===================
# Email (Resend)
# ===================

# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=

# Sender address for pulse reports and password reset emails
# EMAIL_FROM=Customer Pulse <pulse@updates.yourdomain.com>

# ===================
# Optional — Google OAuth
# ===================

# Enables "Continue with Google" on the login page
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ===================
# Optional — Webhook verification
# ===================

# Slack webhook signature verification
# SLACK_SIGNING_SECRET=

# Linear webhook verification (per-integration secrets are preferred)
# LINEAR_WEBHOOK_SECRET=

# ===================
# Optional — Bull Board (queue admin UI)
# ===================

# BULL_BOARD_PORT=3002
# BULL_BOARD_USER=admin
# BULL_BOARD_PASS=change-me
# NEXT_PUBLIC_BULL_BOARD_URL=http://localhost:3002

# ===================
# Multi-tenant (database-per-tenant)
# ===================

# Set to "true" to enable multi-tenant mode (subdomain-based tenant isolation).
# When not set, the app runs in single-tenant mode using DATABASE_URL only.
# MULTI_TENANT=true

# Control plane database (tenant registry + user auth).
# Only required when MULTI_TENANT=true.
# CONTROL_PLANE_DATABASE_URL=postgres://localhost:5432/customer_pulse_control_plane

# Cookie domain for cross-subdomain Auth.js sessions (e.g. ".customerpulse.app").
# Only required when MULTI_TENANT=true.
# AUTH_COOKIE_DOMAIN=.customerpulse.app

# Base domain for subdomain parsing (e.g. "customerpulse.app").
# In dev, use "localhost:3001" and access tenants via ?tenant=slug.
# APP_BASE_DOMAIN=customerpulse.app

# Neon API credentials for programmatic database provisioning.
# NEON_API_KEY=
# NEON_PROJECT_ID=

# ===================
# Dev/testing only
# ===================

# Enable demo data seeding button in Settings (admin only)
# ALLOW_DEMO_DATA_SEED=true
